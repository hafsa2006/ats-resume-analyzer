# Server
PORT=5000
FRONTEND_URL=http://localhost:5173

# MongoDB — use ONE of these options:

# Option A: Local MongoDB (most reliable for dev on Windows)
# MONGO_URI=mongodb://127.0.0.1:27017/ats_analyzer
# USE_LOCAL_MONGO=true

# Option B: Atlas SRV connection (mongodb+srv://...)
# MONGO_URI=mongodb+srv://USER:PASS@cluster0.xxxxx.mongodb.net/ats_analyzer?retryWrites=true&w=majority

# Option C: Atlas STANDARD connection (use if you see querySrv ECONNREFUSED)
# Atlas → Connect → Drivers → copy the string that starts with mongodb:// (NOT mongodb+srv)
MONGO_URI_STANDARD=

# Auth
JWT_SECRET=change-me-in-production

# Gemini (optional)
GEMINI_API_KEY=
