# Server
PORT=5000
FRONTEND_URL=http://localhost:5173

# MongoDB
MONGO_URI=mongodb://localhost:27017/ats_analyzer

# Auth
JWT_SECRET=change-me-in-production

# When MongoDB is unreachable, still start the API (dashboard uses mock stats)
ALLOW_START_WITHOUT_DB=true

# Force mock dashboard data even when DB is connected
MOCK_DASHBOARD=false

# Gemini (optional — analysis uses deterministic engine without it)
GEMINI_API_KEY=
